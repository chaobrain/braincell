{
  "meta": {
    "label": "CV count scan"
  },
  "base": {
    "simulation": {
      "dt_ms": 0.025,
      "duration_ms": 2.0,
      "v_init_mV": -65.0
    },
    "cable": {
      "ra_ohm_cm": 100.0,
      "cm_uF_cm2": 1.0
    },
    "cv_policy": {
      "kind": "CVPerBranch",
      "cv_per_branch": 3
    },
    "stimulus": {
      "kind": "dc_step",
      "target": "root_soma_midpoint",
      "delay_ms": 0.5,
      "dur_ms": 1.0,
      "amp_nA": 0.05
    }
  },
  "group": {
    "group_id": "cv",
    "description": "Sweep CV count per branch.",
    "sweep_axes": {
      "cv_policy.cv_per_branch": [1, 3, 5]
    }
  },
  "outputs": {
    "plot": false
  }
}
